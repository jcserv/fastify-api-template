  "lint-staged": {
    "*.{ts,js,mjs,cjs}": [
      "oxlint --fix",
      "oxfmt"
    ]
  },
  "dependencies": {
    "fastify": "^5.8.5"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "pino-pretty": "^13.1.3",
    "rolldown": "^1.1.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@10.30.3"
}
