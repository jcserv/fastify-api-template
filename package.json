{
  "name": "outbox",
  "version": "1.0.0",
  "description": "",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "src/server.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "oxlint && oxfmt --check",
    "lint:fix": "oxlint --fix && oxfmt",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "node --watch src/server.ts",
    "build": "rolldown -c",
    "start": "node dist/server.js",
    "prepare": "husky"
